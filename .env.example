# Database connection string (replace all placeholders with your actual values)
DATABASE_URL=postgres://myapp_user:myapp_password@localhost:5432/myapp_db

# JWT secret used for signing tokens.
# Generate a secure secret with: openssl rand -base64 32
# Never commit your real secret to version control.
JWT_SECRET=replace_with_a_cryptographically_secure_random_string

# Google Gemini API key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# HTTP port the server listens on (optional, defaults to 3000)
PORT=3000

# SMTP settings for login-notification emails (all optional — email sending is
# skipped when SMTP_HOST is not set)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp_username
SMTP_PASS=smtp_password
SMTP_FROM=no-reply@example.com
SMTP_SUBJECT_PREFIX=S.M.U.V.E 2.0
